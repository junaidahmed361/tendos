{
  "name": "mle-interview-tutor",
  "version": "0.1.2",
  "author": "junaidahmed361",
  "domain": "interview-prep",
  "description": "Containerized local MLE interview tutoring agent cartridge aligned with daily lesson runner teaching contract.",
  "license": "Apache-2.0",
  "tags": ["mle", "interview", "tutor", "ollama", "qwen", "local"],
  "model": {
    "base": "qwen2.5-coder:3b",
    "source": "ollama",
    "inference_params": {
      "temperature": 0.2,
      "max_tokens": 2048,
      "top_p": 0.9
    }
  },
  "agent": {
    "system_prompt": "prompts/system.txt",
    "tools": []
  },
  "harness": {
    "yaml_path": "harness/harness.yaml",
    "declarations": {
      "security_guardrails": [
        "prompt_injection_detection",
        "tool_allowlist",
        "local_filesystem_scope"
      ],
      "pii_redaction": {
        "enabled": true,
        "strategy": "mask",
        "entities": ["email", "phone", "ssn", "credit_card"]
      },
      "update_sync": {
        "strategy": "signed_pull",
        "interval": "weekly",
        "signed_updates_required": true
      },
      "custom_config": {
        "launcher": {
          "type": "docker",
          "image": "tendos/mle-interview-tutor:0.1.2",
          "build": {"context": ".", "dockerfile": "harness/Dockerfile"},
          "env": {"OLLAMA_MODEL": "qwen2.5-coder:3b"},
          "volumes": ["tendos-mle-ollama:/root/.ollama"],
          "command": "hermes",
          "args": [
            "chat",
            "-q",
            "Teach Arrays & Hashing for MLE interview prep with subtopic counter 1/14 and ask 3 warmup recall questions.",
            "-m",
            "ollama/qwen2.5-coder:3b",
            "-Q"
          ]
        }
      }
    }
  },
  "privacy": {
    "data_stays_local": true,
    "compliance_attestations": ["local-first"]
  }
}
